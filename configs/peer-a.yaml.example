peer_id: "peer-a"
database_path: "/tmp/crdt-agent-memory-dev/peer-a/agent_memory.sqlite"
signing_key_path: "/tmp/crdt-agent-memory-dev/peer-a/peer.key"
namespaces:
  - "team/dev"
transport:
  discovery_profile: "http-dev"
  relay_profile: "none"
api:
  listen_addr: "127.0.0.1:3101"
  base_url: "http://127.0.0.1:3101"
sync:
  listen_addr: "127.0.0.1:3201"
  public_url: "http://127.0.0.1:3201"
  interval_ms: 3000
  batch_limit: 256
  once_timeout_ms: 5000
search:
  profile: "default"
  fts_tokenizer: "unicode61"
  ranking_profile: "default"
embedding:
  provider: "local"
  model: ""
  base_url: ""
  dimension: 8
  timeout_ms: 3000
peer_registry:
  - peer_id: "peer-b"
    display_name: "peer-b"
    signing_public_key: "8fb9528d24f03b3f5384808d4708e2f42b7a017fb00d664ca06bd5ed0b4d8d8c"
    namespace_allowlist: ["team/dev"]
    discovery_profile: "http-dev"
    relay_profile: "none"
