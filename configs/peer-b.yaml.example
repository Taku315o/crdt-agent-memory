peer_id: "peer-b"
database_path: "/tmp/crdt-agent-memory-dev/peer-b/agent_memory.sqlite"
signing_key_path: "/tmp/crdt-agent-memory-dev/peer-b/peer.key"
namespaces:
  - "team/dev"
transport:
  discovery_profile: "http-dev"
  relay_profile: "none"
api:
  listen_addr: "127.0.0.1:3102"
  base_url: "http://127.0.0.1:3102"
sync:
  listen_addr: "127.0.0.1:3202"
  public_url: "http://127.0.0.1:3202"
  interval_ms: 3000
  batch_limit: 256
  once_timeout_ms: 5000
peer_registry:
  - peer_id: "peer-a"
    display_name: "peer-a"
    signing_public_key: "2fcb1b4f37913cdfd7b1b5d997f67ea650bea13266016cf4adf2ac1e1f89ac3d"
    namespace_allowlist: ["team/dev"]
    discovery_profile: "http-dev"
    relay_profile: "none"
    sync_url: "http://127.0.0.1:3201"
